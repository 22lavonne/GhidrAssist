<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/"
     xml:base="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#belongsToBinary -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#belongsToBinary">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#containsModule"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#BinaryNode"/>
        <rdfs:comment>inverse of containsModule</rdfs:comment>
        <rdfs:label>belongsToBinary</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#belongsToModule -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#belongsToModule">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#containsFunction"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:comment>where a node (function) belongs to a module / community cluster</rdfs:comment>
        <rdfs:label>belongsToModule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#bequeaths -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#bequeaths">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#inherits"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:comment>inverse of inherits</rdfs:comment>
        <rdfs:label>bequeaths</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#callsVulnerable -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#callsVulnerable">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/calls"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#vulnerableVia"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>where one fuction calls or uses another vulnerable function, directed from caller to vulnerable callee</rdfs:comment>
        <rdfs:label>callsVulnerable</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#containsFunction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#containsFunction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>hierarchical containment between module and function</rdfs:comment>
        <rdfs:label>containsFunction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#containsModule -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#containsModule">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#BinaryNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:comment>hierarchical containment from binary to module</rdfs:comment>
        <rdfs:label>containsModule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#contentFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#contentFor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#hasContent"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#Content"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#definedInNamespace -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#definedInNamespace">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/namespaceDefines"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Class"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/DLL"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Namespace"/>
        <rdfs:comment>specifys the objects that can be defined within a given namespace</rdfs:comment>
        <rdfs:label>definedInNamespace</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#defines -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#defines">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/definedIn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/StructuralNamespaceSymbol"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/Label"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>specifies a function or label that the given namespace defines (specifically the structural namespace symbol)</rdfs:comment>
        <rdfs:label>defines</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#definesLocal -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#definesLocal">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#localDefinedIn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/LocalVariable"/>
        <rdfs:comment>Specifies a local variable that a function defines locally</rdfs:comment>
        <rdfs:label>definesLocal</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#dependsOnFunction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#dependsOnFunction">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#providesDependencyTo"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>logical dependency between functions</rdfs:comment>
        <rdfs:label>dependsOnFunction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#dependsOnModule -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#dependsOnModule">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#moduleDependencyTo"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:comment>logical dependency between modules</rdfs:comment>
        <rdfs:label>dependsOnModule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#functionRelatedTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#functionRelatedTo">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#relatedToFunction"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>inverse of relatedToFunction</rdfs:comment>
        <rdfs:label>functionRelatedTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#functionalSibling -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#functionalSibling">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>functions that are siblings in the same module</rdfs:comment>
        <rdfs:label>sibling</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#hasContent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#hasContent">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#Content"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#hasFeatures -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#hasFeatures">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#Content"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#hasMetadata -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#hasMetadata">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#metadataFor"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#Metadata"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#inferredCalledBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#inferredCalledBy">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/calledBy"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#inferredCalls"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>inverse of inferredCalls</rdfs:comment>
        <rdfs:label>inferredCalledBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#inferredCalls -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#inferredCalls">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/calls"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>heuristic function call relationship inferred from decompiled content</rdfs:comment>
        <rdfs:label>inferredCalls</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#inherits -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#inherits">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:comment>type/class inheritance relationships</rdfs:comment>
        <rdfs:label>inherits</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#localDefinedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#localDefinedIn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/LocalVariable"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>specifies which function an local variable is defined in</rdfs:comment>
        <rdfs:label>localDefinedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#metadataFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#metadataFor">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#Metadata"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#moduleDependencyTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#moduleDependencyTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:comment>inverse of dependsOnModule</rdfs:comment>
        <rdfs:label>moduleDependencyTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#networkRecv -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#networkRecv">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#networkSend"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>inverse of networkSend</rdfs:comment>
        <rdfs:label>networkRecv</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#networkSend -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#networkSend">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>connection from caller to network send API</rdfs:comment>
        <rdfs:label>networkSend</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#providesDependencyTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#providesDependencyTo">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>inverse of dependsOnFunction</rdfs:comment>
        <rdfs:label>functionDependencyTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#referencedBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#referencedBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#references"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:comment>inverse of references</rdfs:comment>
        <rdfs:label>referencedBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#references -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#references">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#KnowledgeNode"/>
        <rdfs:comment>cross-references</rdfs:comment>
        <rdfs:label>references</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#relatedToFunction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#relatedToFunction">
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:comment>related functionality without a direct call relationship from a module to a function</rdfs:comment>
        <rdfs:label>relatedToFunction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#relatedToModule -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#relatedToModule">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#ModuleNode"/>
        <rdfs:comment>related functionality without direct call relationship between modules</rdfs:comment>
        <rdfs:label>relatedToModule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#similarPurpose -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology#similarPurpose">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/symbol-ontology/FunctionNode"/>
