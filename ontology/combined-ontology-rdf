<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/"
     xml:base="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#dependencyTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#dependencyTo">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#dependsOn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:comment>inverse of dependsOn</rdfs:comment>
        <rdfs:label>dependencyTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#dependsOn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#dependsOn">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:comment>local dependency between components</rdfs:comment>
        <rdfs:label>dependsOn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#hasNode -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#hasNode">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#nodeHasAddress"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Address"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Metadata"/>
        <rdfs:comment>inverse of nodeHasAddress</rdfs:comment>
        <rdfs:label>hasNode</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#nodeHasAddress -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#nodeHasAddress">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Metadata"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Address"/>
        <rdfs:comment>indicates the memory address the node is located at</rdfs:comment>
        <rdfs:label>nodeHasAddress</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#relatedTo -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#relatedTo">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:comment>signifies related functionality without a direct call relationship</rdfs:comment>
        <rdfs:label>relatedTo</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#symbolHasAddress -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#symbolHasAddress">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasSymbol"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Symbol"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Address"/>
        <rdfs:comment>specifies the memory address the symbol is located in</rdfs:comment>
        <rdfs:label>symbolHasAddress</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/atAddress -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/atAddress">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/memoryContainsInstruction"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Instruction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Address"/>
        <rdfs:comment>specifies where an instruction is located in memory</rdfs:comment>
        <rdfs:label>atAddress</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/belongsToBinary -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/belongsToBinary">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsModule"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/ModuleNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/BinaryNode"/>
        <rdfs:comment>inverse of containsModule</rdfs:comment>
        <rdfs:label>belongsToBinary</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/belongsToModule -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/belongsToModule">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsFunction"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/ModuleNode"/>
        <rdfs:comment>where a node (function) belongs to a module / community cluster</rdfs:comment>
        <rdfs:label>belongsToCommunity</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/bequeaths -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/bequeaths">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/inherits"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:comment>inverse of inherits</rdfs:comment>
        <rdfs:label>bequeaths</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/calledBy -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/calledBy">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/calls"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:comment>inverse of calls</rdfs:comment>
        <rdfs:label>calledBy</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/calls -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/calls">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:comment>specifies a calling relation between a function and another function</rdfs:comment>
        <rdfs:label>calls</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/callsVulnerable -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/callsVulnerable">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/calls"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/vulnerableVia"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:comment>where one fuction calls or uses another vulnerable function, directed from caller to vulnerable callee</rdfs:comment>
        <rdfs:label>callsVulnerable</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containedIn">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsInstruction"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Instruction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:comment>inverse of containsInstruction (function containsInstruction instruction)</rdfs:comment>
        <rdfs:label>containedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsFunction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsFunction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/ModuleNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:comment>hierarchical containment between module and function</rdfs:comment>
        <rdfs:label>containsFunction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsInstruction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsInstruction">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Instruction"/>
        <rdfs:comment>specifies the instructions contained in a specific function</rdfs:comment>
        <rdfs:label>containsInstruction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsModule -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsModule">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/BinaryNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/ModuleNode"/>
        <rdfs:comment>hierarchical containment from binary to module</rdfs:comment>
        <rdfs:label>containsModule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/contentFor -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/contentFor">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasContent"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Content"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:comment>inverse of hasContent</rdfs:comment>
        <rdfs:label>contentFor</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/definedIn -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/definedIn">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/defines"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Label"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/StructuralNamespaceSymbol"/>
        <rdfs:comment>specifies the namespace symbol that the function is defined in</rdfs:comment>
        <rdfs:label>definedIn</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/definedInNamespace -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/definedInNamespace">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/namespaceDefines"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Class"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/DLL"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Namespace"/>
        <rdfs:comment>specifys the objects that can be defined within a given namespace</rdfs:comment>
        <rdfs:label>definedInNamespace</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/defines -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/defines">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/StructuralNamespaceSymbol"/>
        <rdfs:range>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Label"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:range>
        <rdfs:comment>specifies a function or label that the given namespace defines (specifically the structural namespace symbol)</rdfs:comment>
        <rdfs:label>defines</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/definesLocal -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/definesLocal">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/localDefinedIn"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/LocalVariable"/>
        <rdfs:comment>Specifies a local variable that a function defines locally</rdfs:comment>
        <rdfs:label>definesLocal</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/dependsOnFunction -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/dependsOnFunction">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#dependsOn"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/providesDependencyTo"/>
        <rdfs:domain>
            <owl:Class>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/ModuleNode"/>
                </owl:unionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:comment>logical dependency between functions</rdfs:comment>
        <rdfs:label>dependsOnFunction</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/dependsOnModule -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/dependsOnModule">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#dependsOn"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/moduleDependencyTo"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/ModuleNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/ModuleNode"/>
        <rdfs:comment>logical dependency between modules</rdfs:comment>
        <rdfs:label>dependsOnModule</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/functionalSibling -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/functionalSibling">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode"/>
        <rdfs:comment>functions that are siblings in the same module</rdfs:comment>
        <rdfs:label>sibling</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasContent -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasContent">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Content"/>
        <rdfs:comment>specifies content related properties for the given node</rdfs:comment>
        <rdfs:label>hasContent</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDestinationAddress -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDestinationAddress">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isDestinationAddressFor"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Reference"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Address"/>
        <rdfs:comment>specifies where the destination address of a given reference is</rdfs:comment>
        <rdfs:label>hasDestinationAddress</rdfs:label>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDestinationOperand -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDestinationOperand">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isDestionationOperandFor"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#FunctionalProperty"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Instruction"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Operand"/>
        <rdfs:comment>specifies the destination operand of a given instruction</rdfs:comment>
        <rdfs:label>hasDestinationOperand</rdfs:label>
