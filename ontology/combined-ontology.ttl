@prefix : <http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xml: <http://www.w3.org/XML/1998/namespace> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@base <http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/> .

<http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology> rdf:type owl:Ontology .

#################################################################
#    Object Properties
#################################################################

###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#dependencyTo
:dependencyTo rdf:type owl:ObjectProperty ;
              owl:inverseOf :dependsOn ;
              rdfs:domain :KnowledgeNode ;
              rdfs:range :KnowledgeNode ;
              rdfs:comment "inverse of dependsOn" ;
              rdfs:label "dependencyTo" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#dependsOn
:dependsOn rdf:type owl:ObjectProperty ;
           rdfs:domain :KnowledgeNode ;
           rdfs:range :KnowledgeNode ;
           rdfs:comment "local dependency between components" ;
           rdfs:label "dependsOn" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#hasNode
:hasNode rdf:type owl:ObjectProperty ;
         owl:inverseOf :nodeHasAddress ;
         rdfs:domain :Address ;
         rdfs:range :Metadata ;
         rdfs:comment "inverse of nodeHasAddress" ;
         rdfs:label "hasNode" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#nodeHasAddress
:nodeHasAddress rdf:type owl:ObjectProperty ;
                rdfs:domain :Metadata ;
                rdfs:range :Address ;
                rdfs:comment "indicates the memory address the node is located at" ;
                rdfs:label "nodeHasAddress" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#relatedTo
:relatedTo rdf:type owl:ObjectProperty ,
                    owl:SymmetricProperty ;
           rdfs:domain :KnowledgeNode ;
           rdfs:range :KnowledgeNode ;
           rdfs:comment "signifies related functionality without a direct call relationship" ;
           rdfs:label "relatedTo" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology#symbolHasAddress
:symbolHasAddress rdf:type owl:ObjectProperty ;
                  owl:inverseOf :hasSymbol ;
                  rdfs:domain :Symbol ;
                  rdfs:range :Address ;
                  rdfs:comment "specifies the memory address the symbol is located in" ;
                  rdfs:label "symbolHasAddress" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/atAddress
:atAddress rdf:type owl:ObjectProperty ;
           owl:inverseOf :memoryContainsInstruction ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain :Instruction ;
           rdfs:range :Address ;
           rdfs:comment "specifies where an instruction is located in memory" ;
           rdfs:label "atAddress" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/belongsToBinary
:belongsToBinary rdf:type owl:ObjectProperty ;
                 owl:inverseOf :containsModule ;
                 rdfs:domain :ModuleNode ;
                 rdfs:range :BinaryNode ;
                 rdfs:comment "inverse of containsModule" ;
                 rdfs:label "belongsToBinary" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/belongsToModule
:belongsToModule rdf:type owl:ObjectProperty ;
                 owl:inverseOf :containsFunction ;
                 rdfs:domain :FunctionNode ;
                 rdfs:range :ModuleNode ;
                 rdfs:comment "where a node (function) belongs to a module / community cluster" ;
                 rdfs:label "belongsToCommunity" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/bequeaths
:bequeaths rdf:type owl:ObjectProperty ;
           owl:inverseOf :inherits ;
           rdfs:domain :KnowledgeNode ;
           rdfs:range :KnowledgeNode ;
           rdfs:comment "inverse of inherits" ;
           rdfs:label "bequeaths" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/calledBy
:calledBy rdf:type owl:ObjectProperty ;
          owl:inverseOf :calls ;
          rdfs:domain :FunctionNode ;
          rdfs:range :FunctionNode ;
          rdfs:comment "inverse of calls" ;
          rdfs:label "calledBy" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/calls
:calls rdf:type owl:ObjectProperty ;
       rdfs:subPropertyOf owl:topObjectProperty ;
       rdfs:domain :FunctionNode ;
       rdfs:range :FunctionNode ;
       rdfs:comment "specifies a calling relation between a function and another function" ;
       rdfs:label "calls" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/callsVulnerable
:callsVulnerable rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :calls ;
                 owl:inverseOf :vulnerableVia ;
                 rdfs:domain :FunctionNode ;
                 rdfs:range :FunctionNode ;
                 rdfs:comment "where one fuction calls or uses another vulnerable function, directed from caller to vulnerable callee" ;
                 rdfs:label "callsVulnerable" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containedIn
:containedIn rdf:type owl:ObjectProperty ;
             owl:inverseOf :containsInstruction ;
             rdfs:domain :Instruction ;
             rdfs:range :FunctionNode ;
             rdfs:comment "inverse of containsInstruction (function containsInstruction instruction)" ;
             rdfs:label "containedIn" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsFunction
:containsFunction rdf:type owl:ObjectProperty ;
                  rdfs:domain :ModuleNode ;
                  rdfs:range :FunctionNode ;
                  rdfs:comment "hierarchical containment between module and function" ;
                  rdfs:label "containsFunction" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsInstruction
:containsInstruction rdf:type owl:ObjectProperty ;
                     rdfs:domain :FunctionNode ;
                     rdfs:range :Instruction ;
                     rdfs:comment "specifies the instructions contained in a specific function" ;
                     rdfs:label "containsInstruction" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/containsModule
:containsModule rdf:type owl:ObjectProperty ;
                rdfs:domain :BinaryNode ;
                rdfs:range :ModuleNode ;
                rdfs:comment "hierarchical containment from binary to module" ;
                rdfs:label "containsModule" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/contentFor
:contentFor rdf:type owl:ObjectProperty ;
            owl:inverseOf :hasContent ;
            rdf:type owl:FunctionalProperty ;
            rdfs:domain :Content ;
            rdfs:range :KnowledgeNode ;
            rdfs:comment "inverse of hasContent" ;
            rdfs:label "contentFor" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/definedIn
:definedIn rdf:type owl:ObjectProperty ;
           rdfs:subPropertyOf owl:topObjectProperty ;
           owl:inverseOf :defines ;
           rdf:type owl:FunctionalProperty ;
           rdfs:domain [ rdf:type owl:Class ;
                         owl:unionOf ( :FunctionNode
                                       :Label
                                     )
                       ] ;
           rdfs:range :StructuralNamespaceSymbol ;
           rdfs:comment "specifies the namespace symbol that the function is defined in" ;
           rdfs:label "definedIn" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/definedInNamespace
:definedInNamespace rdf:type owl:ObjectProperty ;
                    owl:inverseOf :namespaceDefines ;
                    rdf:type owl:FunctionalProperty ;
                    rdfs:domain [ rdf:type owl:Class ;
                                  owl:unionOf ( :Class
                                                :DLL
                                              )
                                ] ;
                    rdfs:range :Namespace ;
                    rdfs:comment "specifys the objects that can be defined within a given namespace" ;
                    rdfs:label "definedInNamespace" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/defines
:defines rdf:type owl:ObjectProperty ;
         rdfs:domain :StructuralNamespaceSymbol ;
         rdfs:range [ rdf:type owl:Class ;
                      owl:unionOf ( :FunctionNode
                                    :Label
                                  )
                    ] ;
         rdfs:comment "specifies a function or label that the given namespace defines (specifically the structural namespace symbol)" ;
         rdfs:label "defines" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/definesLocal
:definesLocal rdf:type owl:ObjectProperty ;
              owl:inverseOf :localDefinedIn ;
              rdfs:domain :FunctionNode ;
              rdfs:range :LocalVariable ;
              rdfs:comment "Specifies a local variable that a function defines locally" ;
              rdfs:label "definesLocal" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/dependsOnFunction
:dependsOnFunction rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :dependsOn ;
                   owl:inverseOf :providesDependencyTo ;
                   rdfs:domain [ rdf:type owl:Class ;
                                 owl:unionOf ( :FunctionNode
                                               :ModuleNode
                                             )
                               ] ;
                   rdfs:range :FunctionNode ;
                   rdfs:comment "logical dependency between functions" ;
                   rdfs:label "dependsOnFunction" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/dependsOnModule
:dependsOnModule rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :dependsOn ;
                 owl:inverseOf :moduleDependencyTo ;
                 rdfs:domain :ModuleNode ;
                 rdfs:range :ModuleNode ;
                 rdfs:comment "logical dependency between modules" ;
                 rdfs:label "dependsOnModule" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/functionalSibling
:functionalSibling rdf:type owl:ObjectProperty ,
                            owl:SymmetricProperty ;
                   rdfs:domain :FunctionNode ;
                   rdfs:range :FunctionNode ;
                   rdfs:comment "functions that are siblings in the same module" ;
                   rdfs:label "sibling" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasContent
:hasContent rdf:type owl:ObjectProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :KnowledgeNode ;
            rdfs:range :Content ;
            rdfs:comment "specifies content related properties for the given node" ;
            rdfs:label "hasContent" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDestinationAddress
:hasDestinationAddress rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       owl:inverseOf :isDestinationAddressFor ;
                       rdf:type owl:FunctionalProperty ;
                       rdfs:domain :Reference ;
                       rdfs:range :Address ;
                       rdfs:comment "specifies where the destination address of a given reference is" ;
                       rdfs:label "hasDestinationAddress" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDestinationOperand
:hasDestinationOperand rdf:type owl:ObjectProperty ;
                       rdfs:subPropertyOf owl:topObjectProperty ;
                       owl:inverseOf :isDestionationOperandFor ;
                       rdf:type owl:FunctionalProperty ;
                       rdfs:domain :Instruction ;
                       rdfs:range :Operand ;
                       rdfs:comment "specifies the destination operand of a given instruction" ;
                       rdfs:label "hasDestinationOperand" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasMetadata
:hasMetadata rdf:type owl:ObjectProperty ;
             owl:inverseOf :metadataFor ;
             rdf:type owl:FunctionalProperty ;
             rdfs:domain :KnowledgeNode ;
             rdfs:range :Metadata ;
             rdfs:comment "specifies metadata related properties of the given node" ;
             rdfs:label "hasMetadata" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasPrimaryReference
:hasPrimaryReference rdf:type owl:ObjectProperty ;
                     rdfs:subPropertyOf owl:topObjectProperty ;
                     owl:inverseOf :isPrimaryReferenceOf ;
                     rdf:type owl:FunctionalProperty ;
                     rdfs:domain :Symbol ;
                     rdfs:range :Reference ;
                     rdfs:comment "specifies the primary reference of a given symbol (since a symbol can have multiple reference, but only one can be designated as the primary)" ;
                     rdfs:label "hasPrimaryReference" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasReference
:hasReference rdf:type owl:ObjectProperty ;
              rdfs:subPropertyOf owl:topObjectProperty ;
              owl:inverseOf :isReferenceFor ;
              rdfs:domain :Symbol ;
              rdfs:range :Reference ;
              rdfs:comment "specifies a reference that the symbol has" ;
              rdfs:label "hasReference" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasSourceAddress
:hasSourceAddress rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty ;
                  owl:inverseOf :isSourceAddressFor ;
                  rdf:type owl:FunctionalProperty ;
                  rdfs:domain :Reference ;
                  rdfs:range :Address ;
                  rdfs:comment "specifies the source address of a given reference" ;
                  rdfs:label "hasSourceAddress" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasSourceOperand
:hasSourceOperand rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf owl:topObjectProperty ;
                  owl:inverseOf :isSourceOperandFor ;
                  rdfs:domain :Instruction ;
                  rdfs:range :Operand ;
                  rdfs:comment "specifies a source operand of a given instruction (can have 0 or more)" ;
                  rdfs:label "hasSourceOperand" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasSymbol
:hasSymbol rdf:type owl:ObjectProperty ;
           rdfs:domain :Address ;
           rdfs:range :Symbol ;
           rdfs:comment "inverse of symbolHasAddress" ;
           rdfs:label "hasSymbol" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/inferredCalledBy
:inferredCalledBy rdf:type owl:ObjectProperty ;
                  rdfs:subPropertyOf :calledBy ;
                  owl:inverseOf :inferredCalls ;
                  rdfs:domain :FunctionNode ;
                  rdfs:range :FunctionNode ;
                  rdfs:comment "inverse of inferredCalls" ;
                  rdfs:label "inferredCalledBy" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/inferredCalls
:inferredCalls rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :calls ;
               rdfs:domain :FunctionNode ;
               rdfs:range :FunctionNode ;
               rdfs:comment "heuristic function call relationship inferred from decompiled content" ;
               rdfs:label "inferredCalls" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/inherits
:inherits rdf:type owl:ObjectProperty ;
          rdfs:domain :KnowledgeNode ;
          rdfs:range :KnowledgeNode ;
          rdfs:comment "type/class inheritance relationships" ;
          rdfs:label "inherits" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isDestinationAddressFor
:isDestinationAddressFor rdf:type owl:ObjectProperty ;
                         rdfs:domain :Address ;
                         rdfs:range :Reference ;
                         rdfs:comment "inverse of hasDestinationAddress" ;
                         rdfs:label "isDestinationAddressFor" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isDestionationOperandFor
:isDestionationOperandFor rdf:type owl:ObjectProperty ;
                          rdfs:domain :Operand ;
                          rdfs:range :Instruction ;
                          rdfs:comment "inverse of hasDestinationOperand" ;
                          rdfs:label "isDestinationOperandFor" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isPrimaryReferenceOf
:isPrimaryReferenceOf rdf:type owl:ObjectProperty ;
                      rdfs:domain :Reference ;
                      rdfs:range :Symbol ;
                      rdfs:comment "inverse of hasPrimaryReference" ;
                      rdfs:label "isPrimaryReferenceFor" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isReferenceFor
:isReferenceFor rdf:type owl:ObjectProperty ;
                rdfs:domain :Reference ;
                rdfs:range :Symbol ;
                rdfs:comment "inverse of hasReference" ;
                rdfs:label "isReferenceFor" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isReturnedBy
:isReturnedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf :returns ;
              rdfs:domain :Parameter ;
              rdfs:range :FunctionNode ;
              rdfs:comment "inverse of returns" ;
              rdfs:label "retrunedBy" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isSourceAddressFor
:isSourceAddressFor rdf:type owl:ObjectProperty ;
                    rdfs:domain :Address ;
                    rdfs:range :Reference ;
                    rdfs:comment "inverse of hasSourceAddress" ;
                    rdfs:label "isSourceAddressFor" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isSourceOperandFor
:isSourceOperandFor rdf:type owl:ObjectProperty ;
                    rdfs:domain :Operand ;
                    rdfs:range :Instruction ;
                    rdfs:comment "inverse of hasSourceOperand" ;
                    rdfs:label "isSourceOperandFor" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/localDefinedIn
:localDefinedIn rdf:type owl:ObjectProperty ;
                rdfs:domain :LocalVariable ;
                rdfs:range :FunctionNode ;
                rdfs:comment "specifies which function an local variable is defined in" ;
                rdfs:label "localDefinedIn" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/memoryContainsInstruction
:memoryContainsInstruction rdf:type owl:ObjectProperty ;
                           rdfs:domain :Address ;
                           rdfs:range :Instruction ;
                           rdfs:comment "inverse of atAddress" ;
                           rdfs:label "memoryContainsInstruction" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/metadataFor
:metadataFor rdf:type owl:ObjectProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Metadata ;
             rdfs:range :KnowledgeNode ;
             rdfs:comment "inverse of hasMetadata" ;
             rdfs:label "metadataFor" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/moduleDependencyTo
:moduleDependencyTo rdf:type owl:ObjectProperty ;
                    rdfs:subPropertyOf :dependencyTo ;
                    rdfs:domain :ModuleNode ;
                    rdfs:range :ModuleNode ;
                    rdfs:comment "inverse of dependsOnModule" ;
                    rdfs:label "moduleDependencyTo" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/namespaceDefines
:namespaceDefines rdf:type owl:ObjectProperty ;
                  rdfs:domain :Namespace ;
                  rdfs:range [ rdf:type owl:Class ;
                               owl:unionOf ( :Class
                                             :DLL
                                           )
                             ] ;
                  rdfs:comment "inverse of definedIn" ;
                  rdfs:label "namespaceDefines" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/networkRecv
:networkRecv rdf:type owl:ObjectProperty ;
             owl:inverseOf :networkSend ;
             rdfs:domain :FunctionNode ;
             rdfs:range :FunctionNode ;
             rdfs:comment "inverse of networkSend" ;
             rdfs:label "networkRecv" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/networkSend
:networkSend rdf:type owl:ObjectProperty ;
             rdfs:domain :FunctionNode ;
             rdfs:range :FunctionNode ;
             rdfs:comment "connection from caller to network send API" ;
             rdfs:label "networkSend" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/passesInto
:passesInto rdf:type owl:ObjectProperty ;
            owl:inverseOf :takesArgument ;
            rdfs:domain :Parameter ;
            rdfs:range :FunctionNode ;
            rdfs:comment "specifies what parameters or data are passed into a function" ;
            rdfs:label "passesInto" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/providesDependencyTo
:providesDependencyTo rdf:type owl:ObjectProperty ;
                      rdfs:subPropertyOf :dependencyTo ;
                      rdfs:domain :FunctionNode ;
                      rdfs:range [ rdf:type owl:Class ;
                                   owl:unionOf ( :FunctionNode
                                                 :ModuleNode
                                               )
                                 ] ;
                      rdfs:comment "inverse of dependsOnFunction" ;
                      rdfs:label "functionDependencyTo" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/referencedBy
:referencedBy rdf:type owl:ObjectProperty ;
              owl:inverseOf :references ;
              rdfs:domain :KnowledgeNode ;
              rdfs:range :KnowledgeNode ;
              rdfs:comment "inverse of references" ;
              rdfs:label "referencedBy" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/references
:references rdf:type owl:ObjectProperty ;
            rdfs:domain :KnowledgeNode ;
            rdfs:range :KnowledgeNode ;
            rdfs:comment "cross-references" ;
            rdfs:label "references" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/relatedToFunction
:relatedToFunction rdf:type owl:ObjectProperty ;
                   rdfs:subPropertyOf :relatedTo ;
                   rdf:type owl:SymmetricProperty ;
                   rdfs:domain :FunctionNode ;
                   rdfs:range :FunctionNode ;
                   rdfs:comment "related functionality without a direct call relationship from a module to a function" ;
                   rdfs:label "relatedToFunction" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/relatedToModule
:relatedToModule rdf:type owl:ObjectProperty ;
                 rdfs:subPropertyOf :relatedTo ;
                 rdf:type owl:SymmetricProperty ;
                 rdfs:domain :ModuleNode ;
                 rdfs:range :ModuleNode ;
                 rdfs:comment "related functionality without direct call relationship between modules" ;
                 rdfs:label "relatedToModule" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/returns
:returns rdf:type owl:ObjectProperty ;
         rdfs:subPropertyOf owl:topObjectProperty ;
         rdf:type owl:FunctionalProperty ;
         rdfs:domain :FunctionNode ;
         rdfs:range :Parameter ;
         rdfs:comment "specifies the variable or data returned from a function" ;
         rdfs:label "returns" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/similarPurpose
:similarPurpose rdf:type owl:ObjectProperty ,
                         owl:SymmetricProperty ;
                rdfs:domain :FunctionNode ;
                rdfs:range :FunctionNode ;
                rdfs:comment "represent functions with similar semantic purpose" ;
                rdfs:label "similarPurpose" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/taintFlowsFrom
:taintFlowsFrom rdf:type owl:ObjectProperty ;
                owl:inverseOf :taintFlowsTo ;
                rdfs:domain :FunctionNode ;
                rdfs:range :FunctionNode ;
                rdfs:comment "inverse of taintFlowsTo" ;
                rdfs:label "taintFlowsFrom" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/taintFlowsTo
:taintFlowsTo rdf:type owl:ObjectProperty ;
              rdfs:domain :FunctionNode ;
              rdfs:range :FunctionNode ;
              rdfs:comment "taint propagation path, directed from taint source through intermediates to sink" ;
              rdfs:label "taintFlowsTo" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/takesArgument
:takesArgument rdf:type owl:ObjectProperty ;
               rdfs:domain :FunctionNode ;
               rdfs:range :Parameter ;
               rdfs:comment "inverse of passesInto" ;
               rdfs:label "takesArgument" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/vulnerableVia
:vulnerableVia rdf:type owl:ObjectProperty ;
               rdfs:subPropertyOf :calledBy ;
               rdfs:domain :FunctionNode ;
               rdfs:range :FunctionNode ;
               rdfs:comment "represents potential vulnerability path, directed from source to sink in taint analysis" ;
               rdfs:label "vulnerableVia" .


#################################################################
#    Data properties
#################################################################

###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/belongsTo
:belongsTo rdf:type owl:DatatypeProperty ;
           rdfs:domain :FunctionNode ;
           rdfs:range xsd:string ;
           rdfs:comment "represents the relation of a function belonging to a community. The function that gets this relation in the extension does not have the target node as an object so instead it's id (which is tracked by the edge itself) is used as the target)." ;
           rdfs:label "belongsToCommunity" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/createdAt
:createdAt rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Metadata ;
           rdfs:range xsd:dateTimeStamp ;
           rdfs:comment "indicates when the node was created" ;
           rdfs:label "createdAt" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasActivityProfile
:hasActivityProfile rdf:type owl:DatatypeProperty ,
                             owl:FunctionalProperty ;
                    rdfs:domain :Content ;
                    rdfs:range xsd:string ;
                    rdfs:comment "indicates the computed activity profile" ;
                    rdfs:label "hasActivityProfile" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasAnalysisDepth
:hasAnalysisDepth rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :Metadata ;
                  rdfs:range xsd:int ;
                  rdfs:comment "indicates how many times the given node has been analyzed" ;
                  rdfs:label "hasAnalysisDepth" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasBinaryID
:hasBinaryID rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Metadata ;
             rdfs:range xsd:string ;
             rdfs:comment "indicates the program hash" ;
             rdfs:label "hasBinaryID" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasCategory
:hasCategory rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Content ;
             rdfs:range xsd:string ;
             rdfs:comment "indicates the semantic category for the function, aka the general purpose/category of the function" ;
             rdfs:label "hasCategory" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDataType
:hasDataType rdf:type owl:DatatypeProperty ,
                      owl:FunctionalProperty ;
             rdfs:domain :Variable ;
             rdfs:range xsd:string ;
             rdfs:comment "The data type of the given variable expressed as a string" ;
             rdfs:label "hasDataType" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDecompiledCode
:hasDecompiledCode rdf:type owl:DatatypeProperty ,
                            owl:FunctionalProperty ;
                   rdfs:domain :Content ;
                   rdfs:range xsd:string ;
                   rdfs:comment "contains all the decompiled code for a function/node" ;
                   rdfs:label "hasDecompiledCode" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDisassembly
:hasDisassembly rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :Content ;
                rdfs:range xsd:string ;
                rdfs:comment "contains all the disassembly for the given function/node" ;
                rdfs:label "hasDisassembly" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasDomain
:hasDomain rdf:type owl:DatatypeProperty ;
           rdfs:domain :Content ;
           rdfs:range xsd:string ;
           rdfs:comment "indicates detected domain names as strings in the function" ;
           rdfs:label "hasDomain" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasFileIOAPI
:hasFileIOAPI rdf:type owl:DatatypeProperty ;
              rdfs:domain :Content ;
              rdfs:range xsd:string ;
              rdfs:comment "indicates file IO API calls in the given function" ;
              rdfs:label "hasFileIOAPI" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasFilePath
:hasFilePath rdf:type owl:DatatypeProperty ;
             rdfs:domain :Content ;
             rdfs:range xsd:string ;
             rdfs:comment "indicates detected file paths as strings in the function" ;
             rdfs:label "hasFilePath" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasID
:hasID rdf:type owl:DatatypeProperty ,
                owl:FunctionalProperty ;
       rdfs:domain :Metadata ;
       rdfs:range xsd:string ;
       rdfs:comment "indicates the UUID for the given node" ;
       rdfs:label "hasID" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasIPAddress
:hasIPAddress rdf:type owl:DatatypeProperty ;
              rdfs:domain :Content ;
              rdfs:range xsd:string ;
              rdfs:comment "indicates detected IP addresses from strings in the function" ;
              rdfs:label "hasIPAddress" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasLLMSummary
:hasLLMSummary rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Content ;
               rdfs:range xsd:string ;
               rdfs:comment "contains the LLM summary for the given function/node" ;
               rdfs:label "hasLLMSummary" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasName
:hasName rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain [ rdf:type owl:Class ;
                       owl:unionOf ( :KnowledgeNode
                                     :Metadata
                                   )
                     ] ;
         rdfs:range xsd:string ;
         rdfs:comment "gets the name of a given function/symbol" ;
         rdfs:label "hasName" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasNetworkAPI
:hasNetworkAPI rdf:type owl:DatatypeProperty ;
               rdfs:domain :Content ;
               rdfs:range xsd:string ;
               rdfs:comment "indicates network api calls present in the given function" ;
               rdfs:label "hasNetworkAPI" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasOpcode
:hasOpcode rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Instruction ;
           rdfs:range xsd:string ;
           rdfs:comment "specifies the opcode as a string of a given instruction" ;
           rdfs:label "hasOpcode" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasOperandIndex
:hasOperandIndex rdf:type owl:DatatypeProperty ;
                 rdfs:subPropertyOf owl:topDataProperty ;
                 rdf:type owl:FunctionalProperty ;
                 rdfs:domain :Reference ;
                 rdfs:range xsd:integer ;
                 rdfs:comment "specifies the operand index of a reference" ;
                 rdfs:label "hasOperandIndex" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasOperandType
:hasOperandType rdf:type owl:DatatypeProperty ,
                         owl:FunctionalProperty ;
                rdfs:domain :Operand ;
                rdfs:range xsd:string ;
                rdfs:comment "specify the type of a given operand as a string" ;
                rdfs:label "hasOperandType" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasOperandValue
:hasOperandValue rdf:type owl:DatatypeProperty ,
                          owl:FunctionalProperty ;
                 rdfs:domain :Operand ;
                 rdfs:range xsd:string ;
                 rdfs:comment "specifies the literal value of an operand as a string" ;
                 rdfs:label "hasOperandValue" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasRawContent
:hasRawContent rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :Content ;
               rdfs:range xsd:string ;
               rdfs:comment "contains the raw content of the node, which can be decompiled code, assembly, description, etc." ;
               rdfs:label "hasRawContent" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasReferenceType
:hasReferenceType rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :Reference ;
                  rdfs:range xsd:string ;
                  rdfs:comment "specifies the reference type given as a string" ;
                  rdfs:label "hasReferenceType" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasRegistryKey
:hasRegistryKey rdf:type owl:DatatypeProperty ;
                rdfs:domain :Content ;
                rdfs:range xsd:string ;
                rdfs:comment "indicates detected registry keys as strings in the function" ;
                rdfs:label "hasRegistryKey" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasReturnType
:hasReturnType rdf:type owl:DatatypeProperty ,
                        owl:FunctionalProperty ;
               rdfs:domain :FunctionNode ;
               rdfs:range xsd:string ;
               rdfs:comment "The data type of the variable returned by a function expressed as a string" ;
               rdfs:label "hasReturnType" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasRiskLevel
:hasRiskLevel rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Content ;
              rdfs:range xsd:string ;
              rdfs:comment "indicates computed risk level (low, medium, or high)" ;
              rdfs:label "hasRiskLevel" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasSecurityFlag
:hasSecurityFlag rdf:type owl:DatatypeProperty ;
                 rdfs:domain :Content ;
                 rdfs:range xsd:string ;
                 rdfs:comment "indicates security annotations given as certain flags for a function" ;
                 rdfs:label "hasSecurityFlag" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasSignature
:hasSignature rdf:type owl:DatatypeProperty ,
                       owl:FunctionalProperty ;
              rdfs:domain :Content ;
              rdfs:range xsd:string ;
              rdfs:comment "indicates the reverse engineering byte signature" ;
              rdfs:label "hasSignature" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasSummaryConfidence
:hasSummaryConfidence rdf:type owl:DatatypeProperty ,
                               owl:FunctionalProperty ;
                      rdfs:domain :Content ;
                      rdfs:range xsd:string ;
                      rdfs:comment "indicates the confidence level from the LLM summary" ;
                      rdfs:label "hasSummaryConfidence" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasURL
:hasURL rdf:type owl:DatatypeProperty ;
        rdfs:domain :Content ;
        rdfs:range xsd:string ;
        rdfs:comment "indicates detected URLs in strings in the function" ;
        rdfs:label "hasURL" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/hasVectorEmbedding
:hasVectorEmbedding rdf:type owl:DatatypeProperty ;
                    rdfs:domain :Content ;
                    rdfs:range xsd:float ;
                    rdfs:comment "indicates any vector embeddings from the node" ;
                    rdfs:label "hasVectorEmbedding" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/isStale
:isStale rdf:type owl:DatatypeProperty ,
                  owl:FunctionalProperty ;
         rdfs:domain :Metadata ;
         rdfs:range xsd:boolean ;
         rdfs:comment "indicates if the given node's summarization is stale" ;
         rdfs:label "isStale" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/symbolHasAddress
:symbolHasAddress rdf:type owl:DatatypeProperty ,
                           owl:FunctionalProperty ;
                  rdfs:domain :Symbol ;
                  rdfs:range xsd:long ;
                  rdfs:comment "specifies where a given symbol is located in memory" ;
                  rdfs:label "symbolHasAddress" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/updatedAt
:updatedAt rdf:type owl:DatatypeProperty ,
                    owl:FunctionalProperty ;
           rdfs:domain :Metadata ;
           rdfs:range xsd:dateTimeStamp ;
           rdfs:comment "indicates the last time the node was updated" ;
           rdfs:label "updatedAt" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/userEdited
:userEdited rdf:type owl:DatatypeProperty ,
                     owl:FunctionalProperty ;
            rdfs:domain :Metadata ;
            rdfs:range xsd:boolean ;
            rdfs:comment "indicates if the user edited the LLM summary" ;
            rdfs:label "userEdited" .


#################################################################
#    Classes
#################################################################

###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Address
:Address rdf:type owl:Class ;
         owl:disjointWith :Reference ;
         rdfs:comment "Physical address in memory" ;
         rdfs:label "Address" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/BinaryNode
:BinaryNode rdf:type owl:Class ;
            rdfs:subClassOf :KnowledgeNode ;
            rdfs:comment "represents overall program semantics and attack surface" ;
            rdfs:label "BinaryNode" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Class
:Class rdf:type owl:Class ;
       rdfs:subClassOf :StructuralNamespaceSymbol ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :definedIn ;
                         owl:someValuesFrom :Namespace
                       ] ;
       rdfs:comment "represents a class in a program (for object oriented programming)" ;
       rdfs:label "Class" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Content
:Content rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :hasDecompiledCode ;
                           owl:someValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasDisassembly ;
                           owl:someValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasLLMSummary ;
                           owl:someValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasRawContent ;
                           owl:someValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasSignature ;
                           owl:someValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasSummaryConfidence ;
                           owl:someValuesFrom xsd:float
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasVectorEmbedding ;
                           owl:someValuesFrom xsd:float
                         ] ;
         rdfs:comment "object that includes all the content related properties for one knowledge node" ;
         rdfs:label "Content" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/DLL
:DLL rdf:type owl:Class ;
     rdfs:subClassOf :FunctionNode ,
                     :StructuralNamespaceSymbol ,
                     [ rdf:type owl:Restriction ;
                       owl:onProperty :definedIn ;
                       owl:someValuesFrom :Namespace
                     ] ;
     rdfs:comment "represents an function defined externally of the given binary" ;
     rdfs:label "ExternalFunctionNode" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/FunctionNode
:FunctionNode rdf:type owl:Class ;
              rdfs:subClassOf :KnowledgeNode ,
                              :NamespaceSymbol ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :calls ;
                                owl:someValuesFrom :FunctionNode
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :containsInstruction ;
                                owl:someValuesFrom :Instruction
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :definedIn ;
                                owl:someValuesFrom :StructuralNamespaceSymbol
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :definesLocal ;
                                owl:someValuesFrom :LocalVariable
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :returns ;
                                owl:someValuesFrom :Parameter
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :returns ;
                                owl:someValuesFrom :Variable
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasName ;
                                owl:someValuesFrom xsd:string
                              ] ,
                              [ rdf:type owl:Restriction ;
                                owl:onProperty :hasReturnType ;
                                owl:someValuesFrom xsd:string
                              ] ;
              rdfs:comment "a function defined by the ghidra decompilation" ;
              rdfs:label "FunctionNode" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Instruction
:Instruction rdf:type owl:Class ;
             rdfs:subClassOf [ rdf:type owl:Restriction ;
                               owl:onProperty :atAddress ;
                               owl:someValuesFrom :Address
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasDestinationOperand ;
                               owl:someValuesFrom :Operand
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasSourceOperand ;
                               owl:someValuesFrom :Operand
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasOpcode ;
                               owl:someValuesFrom xsd:string
                             ] ,
                             [ rdf:type owl:Restriction ;
                               owl:onProperty :hasReturnType ;
                               owl:someValuesFrom xsd:string
                             ] ;
             rdfs:comment "assembly instruction gotten from the disassembly in ghidra" ;
             rdfs:label "Instruction" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/KnowledgeNode
:KnowledgeNode rdf:type owl:Class ;
               rdfs:subClassOf [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasContent ;
                                 owl:someValuesFrom :Content
                               ] ,
                               [ rdf:type owl:Restriction ;
                                 owl:onProperty :hasMetadata ;
                                 owl:someValuesFrom :Metadata
                               ] ;
               rdfs:comment "represents the semantic graph nodes from GhidrAssist" ;
               rdfs:label "KnowledgeNode" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Label
:Label rdf:type owl:Class ;
       rdfs:subClassOf :Symbol ,
                       [ rdf:type owl:Restriction ;
                         owl:onProperty :definedIn ;
                         owl:someValuesFrom :StructuralNamespaceSymbol
                       ] ;
       owl:disjointWith :NamespaceSymbol ;
       rdfs:comment "a string name given to a memory address, acts like a global variable in the context of this ontology" ;
       rdfs:label "Label" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/LocalVariable
:LocalVariable rdf:type owl:Class ;
               rdfs:subClassOf :Variable ;
               owl:disjointWith :Parameter ;
               rdfs:comment "the variables defined within a function and only used locally" ;
               rdfs:label "LocalVariable" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Metadata
:Metadata rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :createdAt ;
                            owl:someValuesFrom xsd:dateTimeStamp
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasAnalysisDepth ;
                            owl:someValuesFrom xsd:int
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasBinaryID ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasID ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :hasName ;
                            owl:someValuesFrom xsd:string
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :isStale ;
                            owl:someValuesFrom xsd:boolean
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :updatedAt ;
                            owl:someValuesFrom xsd:dateTimeStamp
                          ] ,
                          [ rdf:type owl:Restriction ;
                            owl:onProperty :userEdited ;
                            owl:someValuesFrom xsd:boolean
                          ] ;
          rdfs:comment "contains the properties of metadata for the given node" ;
          rdfs:label "Metadata" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/ModuleNode
:ModuleNode rdf:type owl:Class ;
            rdfs:subClassOf :KnowledgeNode ;
            rdfs:comment "represents subsystems and logial groupings" ;
            rdfs:label "ModuleNode" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Namespace
:Namespace rdf:type owl:Class ;
           rdfs:subClassOf :StructuralNamespaceSymbol ;
           rdfs:comment "a namespace defined by the ghidra decompilation" ;
           rdfs:label "Namespace" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/NamespaceSymbol
:NamespaceSymbol rdf:type owl:Class ;
                 rdfs:subClassOf :Symbol ;
                 rdfs:comment "a type of symbol that can hold other kinds of symbols" ;
                 rdfs:label "NamespaceSymbol" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Operand
:Operand rdf:type owl:Class ;
         rdfs:subClassOf [ rdf:type owl:Restriction ;
                           owl:onProperty :hasOperandType ;
                           owl:someValuesFrom xsd:string
                         ] ,
                         [ rdf:type owl:Restriction ;
                           owl:onProperty :hasOperandValue ;
                           owl:someValuesFrom xsd:string
                         ] ;
         rdfs:comment "operand for an instruction, tells the CPU where to use or put the data from an instruction" ;
         rdfs:label "Operand" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Parameter
:Parameter rdf:type owl:Class ;
           rdfs:subClassOf :Variable ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :passesInto ;
                             owl:someValuesFrom :FunctionNode
                           ] ;
           rdfs:comment "the variables that hold data that are either passed into a function or returned from a function" ;
           rdfs:label "Parameter" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Reference
:Reference rdf:type owl:Class ;
           rdfs:subClassOf [ rdf:type owl:Restriction ;
                             owl:onProperty :hasDestinationAddress ;
                             owl:someValuesFrom :Address
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasSourceAddress ;
                             owl:someValuesFrom :Address
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasOperandIndex ;
                             owl:someValuesFrom xsd:integer
                           ] ,
                           [ rdf:type owl:Restriction ;
                             owl:onProperty :hasReferenceType ;
                             owl:someValuesFrom xsd:string
                           ] ;
           rdfs:comment "This class represents an identifier to a symbol, that uses a source address and destination address to do so." ;
           rdfs:label "Reference" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/ReverseEngineeringFeatures
:ReverseEngineeringFeatures rdf:type owl:Class ;
                            rdfs:subClassOf [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasActivityProfile ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasCategory ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasDomain ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasFileIOAPI ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasFilePath ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasIPAddress ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasNetworkAPI ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasRegistryKey ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasRiskLevel ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasSecurityFlag ;
                                              owl:someValuesFrom xsd:string
                                            ] ,
                                            [ rdf:type owl:Restriction ;
                                              owl:onProperty :hasURL ;
                                              owl:someValuesFrom xsd:string
                                            ] ;
                            rdfs:comment "indicates the reverse engineering feature data properties for a given node (only applies to FunctionNodes)" ;
                            rdfs:label "ReverseEngineeringFeatures" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/StructuralNamespaceSymbol
:StructuralNamespaceSymbol rdf:type owl:Class ;
                           rdfs:subClassOf :NamespaceSymbol ;
                           rdfs:comment "A type of namespace symbol that can define non-local symbols (all namespace symbols that are not functions since they operate differently)" ;
                           rdfs:label "StructuralNamespaceSymbol" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Symbol
:Symbol rdf:type owl:Class ;
        rdfs:subClassOf [ rdf:type owl:Restriction ;
                          owl:onProperty :atAddress ;
                          owl:someValuesFrom :Address
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasPrimaryReference ;
                          owl:someValuesFrom :Reference
                        ] ,
                        [ rdf:type owl:Restriction ;
                          owl:onProperty :hasReference ;
                          owl:someValuesFrom :Reference
                        ] ;
        rdfs:comment "an association between a memory address and name" ;
        rdfs:label "Symbol" .


###  http://www.semanticweb.org/jaspe/ontologies/2026/0/combined-ontology/Variable
:Variable rdf:type owl:Class ;
          rdfs:subClassOf [ rdf:type owl:Restriction ;
                            owl:onProperty :hasDataType ;
                            owl:someValuesFrom xsd:string
                          ] ;
          rdfs:comment "a type of object that holds data within a function" ;
          rdfs:label "Variable" .


#################################################################
#    General axioms
#################################################################

[ rdf:type owl:AllDisjointClasses ;
  owl:members ( :Class
                :DLL
                :FunctionNode
                :Namespace
              )
] .


